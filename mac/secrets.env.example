# このファイルを ~/.config/secrets.env にコピーして実際の値を記入する。
# 実体ファイル (secrets.env) は .gitignore でコミット対象外。
# .zprofile / .zshrc がこのファイルを source して環境変数を読み込む。
# OPENAI_API_KEY は ccgate (Claude Code / Codex の PermissionRequest フック) が利用する。

export OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
