# Secrets - 実体ファイルは絶対にコミットしない (.example のみ追跡)
secrets.env
**/secrets.env
*.local

# 環境変数ファイル(Grafana Cloud トークン等) と 一時/ローカル専用スクリプト
.env
**/.env
*.local.ps1
**/*.local.ps1

# Claude Code - exclude ephemeral state
claude/history.jsonl
claude/sessions/
claude/cache/
claude/projects/
claude/tasks/
claude/plans/
claude/backups/
claude/paste-cache/
claude/file-history/
claude/shell-snapshots/
claude/telemetry/
claude/mcp-needs-auth-cache.json
claude/ide/
