{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4317",
    "OTEL_METRIC_EXPORT_INTERVAL": "10000"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Bash(*)",
      "Write(*)",
      "Edit(*)",
      "WebFetch",
      "Bash(git push:*)"
    ],
    "deny": [
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Read(**/.env)",
      "Read(**/secrets/**)",
      "Read(**/config/**)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(git rebase:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  },
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ccgate claude"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "interaction": {
    "confirmationMode": "minimal"
  }
}
